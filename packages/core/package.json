{
  "name": "@clockchain/core",
  "version": "0.1.0",
  "description": "Typed client for the Clockchain network gateway API",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": ["clockchain", "blockchain", "timestamp", "notarization", "agent"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thetangstr/clockchain-developer-tools.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "tsc -b && node --test",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
