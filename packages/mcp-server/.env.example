# Clockchain MCP server - host config (v2). Copy to .env and fill in.
# Secrets (API key, tester tokens) stay on the host; never commit .env.

# --- transport ---
MCP_TRANSPORT=http            # "http" for the hosted endpoint; omit or "stdio" for local agents
MCP_PORT=3000

# --- Clockchain gateway (required) ---
CLOCKCHAIN_API_KEY=           # stays on the host; testers never see it
CLOCKCHAIN_CLIENT_ID=you@example.com
CLOCKCHAIN_WALLET_ID=you@example.com
# CLOCKCHAIN_ENDPOINT=https://node.clockchain.network   # default; override only if needed

# --- tester auth (recommended for any networked host) ---
# Comma-separated tokens. A tester sends one as either:
#   Authorization: Bearer <token>   OR   x-api-key: <token>
MCP_AUTH_TOKENS=tester-a,tester-b

# --- safety: per-process cap on successful log writes (v2) ---
MCP_LOG_BUDGET=200            # optional; unset = unlimited

# --- observability ---
# MCP_LOG=off                 # optional; silences the per-call stderr trace

# --- ERC-8004 identity read (optional; resolve_agent returns "unknown" until set) ---
# EVM_RPC_URL=
# ERC8004_CHAIN=base-sepolia
# ERC8004_REGISTRY_ADDRESS=
